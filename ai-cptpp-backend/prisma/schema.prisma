generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  MANAGER
  CLIENT
  TEAM_MEMBER
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  MOBILE_MONEY
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CommunicationType {
  MESSAGE
  NOTIFICATION
  REPORT
  DOCUMENT
}

enum CommunicationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum AIAnalysisType {
  PROJECT_RISK
  PROJECT_SUMMARY
  TASK_PREDICTION
  SENTIMENT_ANALYSIS
  TEAM_PRODUCTIVITY
  BUDGET_ANALYSIS
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password_hash String
  role          UserRole @default(CLIENT)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  managed_projects        Project[] @relation("ProjectManager")
  client_projects         Project[] @relation("ProjectClient")
  team_memberships        TeamMember[]
  assigned_tasks          Task[]
  sent_communications     Communication[] @relation("CommunicationSender")
  received_communications Communication[] @relation("CommunicationReceiver")
  invoices                Invoice[]
  refresh_tokens          RefreshToken[]
  ai_analyses             AIAnalysis[]

  @@map("users")
}

//////////////////////////////////////////////////////
// PROJECTS
//////////////////////////////////////////////////////

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(DRAFT)
  budget      Float?
  client_id   String
  manager_id  String
  start_date  DateTime?
  end_date    DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  client        User @relation("ProjectClient", fields: [client_id], references: [id])
  manager       User @relation("ProjectManager", fields: [manager_id], references: [id])

  team_members  TeamMember[]
  tasks         Task[]
  invoices      Invoice[]
  communications Communication[]
  ai_analyses   AIAnalysis[]

  @@map("projects")
}

//////////////////////////////////////////////////////
// TEAM MEMBERS
//////////////////////////////////////////////////////

model TeamMember {
  id         String   @id @default(cuid())
  project_id String
  user_id    String
  role       String
  joined_at  DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@map("team_members")
}

//////////////////////////////////////////////////////
// TASKS
//////////////////////////////////////////////////////

model Task {
  id          String       @id @default(cuid())
  project_id  String
  assigned_to String?
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  due_date    DateTime?
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  project   Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignee  User?   @relation(fields: [assigned_to], references: [id])

  ai_analyses AIAnalysis[]

  @@map("tasks")
}

//////////////////////////////////////////////////////
// INVOICES
//////////////////////////////////////////////////////

model Invoice {
  id         String        @id @default(cuid())
  project_id String
  client_id  String
  amount     Float
  due_date   DateTime
  status     InvoiceStatus @default(PENDING)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  project  Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  client   User    @relation(fields: [client_id], references: [id], onDelete: Cascade)

  payments Payment[]

  @@map("invoices")
}

//////////////////////////////////////////////////////
// PAYMENTS
//////////////////////////////////////////////////////

model Payment {
  id         String        @id @default(cuid())
  invoice_id String
  amount     Float
  method     PaymentMethod
  status     PaymentStatus @default(COMPLETED)
  paid_at    DateTime      @default(now())
  created_at DateTime      @default(now())

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

//////////////////////////////////////////////////////
// COMMUNICATIONS
//////////////////////////////////////////////////////

model Communication {
  id          String              @id @default(cuid())
  project_id  String?
  sender_id   String?
  receiver_id String?
  subject     String?
  body        String
  file_url    String?
  type        CommunicationType   @default(MESSAGE)
  status      CommunicationStatus @default(UNREAD)
  created_at  DateTime            @default(now())

  project  Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)

  sender   User? @relation("CommunicationSender", fields: [sender_id], references: [id])
  receiver User? @relation("CommunicationReceiver", fields: [receiver_id], references: [id])

  ai_analyses AIAnalysis[]

  @@map("communications")
}

//////////////////////////////////////////////////////
// AI ANALYSIS
//////////////////////////////////////////////////////

model AIAnalysis {
  id               String         @id @default(cuid())
  project_id       String?
  task_id          String?
  communication_id String?
  user_id          String?

  analysis_type AIAnalysisType
  result        String
  confidence    Float?
  metadata      Json?

  created_at DateTime @default(now())

  project       Project?       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  task          Task?          @relation(fields: [task_id], references: [id], onDelete: Cascade)
  communication Communication? @relation(fields: [communication_id], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("ai_analyses")
}

//////////////////////////////////////////////////////
// REFRESH TOKENS
//////////////////////////////////////////////////////

model RefreshToken {
  id         String   @id @default(cuid())
  user_id    String
  token String @db.Text
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}